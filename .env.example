MODAL_TOKEN_SECRET=

# Optional — Google Safe Browsing for passive blacklist check
GOOGLE_SAFE_BROWSING_API_KEY=

# Kimi fix prompts (Modal secret moonshot-key — not needed on Vercel)
# MOONSHOT_API_KEY=   (set in Modal dashboard only)
# KIMI_MODEL=kimi-k2.5

# GitHub App
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_WEBHOOK_SECRET=
# Public slug from the app URL: github.com/apps/<slug>
NEXT_PUBLIC_GITHUB_APP_SLUG=

# Internal
SCANNER_CALLBACK_SECRET=
RESEND_API_KEY=
RESEND_FROM_EMAIL=IsMySiteSecure <scans@ismysitesecure.ai>

# Vercel Cron — daily follow-up emails (Bearer token on /api/cron/email-followups)
CRON_SECRET=

# App (canonical URL for links/emails; www if apex redirects to www)
NEXT_PUBLIC_APP_URL=
# Optional: API origin for Modal callbacks if different from NEXT_PUBLIC_APP_URL
# CALLBACK_APP_URL=https://www.ismysitesecure.ai
